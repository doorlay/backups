<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.doorlay.backups</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
	  <string>~/Projects/backups/run.sh</string>    
</array>

    <key>RunAtLoad</key>
    <true/>

    <!-- Every hour (from time of load; not aligned to top-of-hour) -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>StandardOutPath</key>
    <string>~/Library/Logs/backups.out.log</string>

    <key>StandardErrorPath</key>
    <string>~/Library/Logs/backups.err.log</string>
  </dict>
</plist>
