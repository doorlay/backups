<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
	<string>com.doorlay.backups</string>

	<key>WorkingDirectory</key>
	<string>/Users/doorlay/Projects/backups</string>

    <key>ProgramArguments</key>
    <array>
		<string>/Users/doorlay/bin/backups</string>
</array>
    <key>RunAtLoad</key>
    <true/>

    <!-- Every hour (from time of load) -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>StandardOutPath</key>
	<string>/Users/doorlay/Library/Logs/backups.out.log</string>

    <key>StandardErrorPath</key>
	<string>/Users/doorlay/Library/Logs/backups.err.log</string>
  </dict>
</plist>
